# =========================================================================
# KL STUDIOS - BACKEND ENVIRONMENT CONFIGURATION
# =========================================================================

# Database Connection (Supabase PostgreSQL / Relational Database)
# Fallback is standard local SQLite 'sqlite:///./klstudios.db' if left empty
SUPABASE_DB_URL=postgresql://postgres:[YOUR_SUPABASE_PASSWORD]@db.[YOUR_PROJECT_ID].supabase.co:6543/postgres

# Security Cryptography JWT Configuration
JWT_SECRET=super-secret-klstudios-key-998877

# Paystack API Credentials (Ghana Cedi Default Payments Integration)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_goes_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_goes_here

# Resend Email Delivery Service Configuration
RESEND_API_KEY=re_your_resend_api_key_goes_here
SENDER_EMAIL=services@klstudios.co

# Twilio or WhatsApp Business API integration
WHATSAPP_API_TOKEN=your_whatsapp_business_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
